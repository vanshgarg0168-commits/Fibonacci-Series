      "source": [
        "# Fibonacci Series\n",
        "\n",
        "n = int(input(\"Enter the number of terms: \"))\n",
        "\n",
        "first = 0\n",
        "second = 1\n",
        "\n",
        "print(\"Fibonacci Series:\")\n",
        "\n",
        "for i in range(n):\n",
        "    print(first, end=\" \")\n",
        "\n",
        "    next_number = first + second\n",
        "    first = second\n",
        "    second = next_number"
      ]
    }
  ]
